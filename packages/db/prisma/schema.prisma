generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceSourceType {
  WEB
  FILE
}

enum WorkspacePlan {
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

model User {
  id            String         @id
  firstName     String
  lastName      String
  email         String         @unique
  workspaces    Workspace[]
  subscription  Subscription?
}

model Workspace {
  id             String          @id @default(uuid())
  name           String
  website        String?
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id])
  plan           WorkspacePlan   @default(STARTER)
  resources      Resource[]
  customers      Customer[]
  conversations  Conversation[]
  notifications  Notification[]
  widgetSettings WidgetSettings?
}

model Resource {
  id          String             @id @default(uuid())
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id])
  sourceType  ResourceSourceType
  url         String?
  paths       String[]           @default([])
  filename    String?
  mimeType    String?
  fileText    String?
  webContent  Json?
  active      Boolean            @default(true)
  updatedAt   DateTime           @default(now())
  createdAt   DateTime           @default(now())
}

model Customer {
  id            String         @id @default(uuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  name          String?
  email         String?
  conversations Conversation[]
  metadata      Json?
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
}

enum ConversationStatus {
  unresolved
  escalated
  resolved
}

model Conversation {
  id          String             @id @default(uuid())
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id])
  customerId  String
  customer    Customer           @relation(fields: [customerId], references: [id])
  threadId    String             @unique
  status      ConversationStatus @default(unresolved)
  notifications Notification[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Notification {
  id             String       @id @default(uuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  type           String
  title          String
  description    String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, isRead])
  @@index([conversationId])
}

model WidgetSettings {
  id                 String    @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  brandName          String?
  companyLogoUrl     String?
  greetMessage       String    @default("Hi! How can I help you today?")
  themeMode          String    @default("light")
  gradientFrom       String    @default("#406AAF")
  themeColor         String    @default("#406AAF")
  defaultSuggestions Json?
  whatsNewSection    Json?
  featuredArticlesSection Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([workspaceId])
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id])
  plan                   WorkspacePlan
  status                 SubscriptionStatus
  razorpaySubscriptionId String?            @unique
  razorpayCustomerId     String?
  razorpayPlanId         String?
  startedAt              DateTime
  endsAt                 DateTime
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}
