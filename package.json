{
  "name": "shadcn-ui-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml watch",
    "docker:prod": "docker compose up",
    "build:backend": "pnpm --filter @workspace/db build && pnpm --filter @workspace/backend build",
    "start:backend": "cd packages/backend && pnpm start",
    "db:generate": "cd packages/db && pnpm exec prisma generate",
    "build:web": "cd apps/web && pnpm build",
    "start:web": "cd apps/web && pnpm start",
    "build:widget": "cd apps/widget && pnpm build",
    "start:widget": "cd apps/widget && pnpm start",
    "lint": "corepack pnpm -r --if-present lint",
    "format": "corepack pnpm exec prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss,yml,yaml}\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  }
}
